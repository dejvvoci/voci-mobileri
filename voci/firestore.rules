rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Produktet: lexo publik, shkruaj vetëm i autentikuar
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Kategoritë: lexo publik, shkruaj vetëm i autentikuar
    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
