rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Media e produkteve (imazhe + video): lexo publik, ngarko vetëm i autentikuar
    match /products/{productId}/{mediaFile} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 200 * 1024 * 1024  // max 200MB (video)
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null;
    }
  }
}
